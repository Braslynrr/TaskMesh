{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "baseUrl": ".",
  },
  "lib": ["es2015"],
  "exclude": [
    "src/tests",
    "**/*.test.ts",
    "jest.config.ts",
    "jest.setup.ts"
  ]
}